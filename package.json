{
  "name": "ai-stack-atlas",
  "version": "0.1.0",
  "type": "module",
  "description": "A trilingual (中/EN/日) knowledge base & comparison hub for the modern AI stack: coding agents, CLIs, agent harnesses & infrastructure.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "validate:data": "node scripts/validate-data.mjs",
    "smoke": "node pw/smoke.mjs",
    "verify": "npm run validate:data && npm run check && npm run build",
    "open": "astro build && start \"\" \"dist/index.html\"",
    "preview": "astro preview",
    "astro": "astro"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "astro": "^7.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "playwright": "^1.61.0",
    "typescript": "^5.9.3"
  }
}
