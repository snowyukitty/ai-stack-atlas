---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import L from '../components/L.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
const fullTitle = title ? `${title} · AI Stack Atlas` : 'AI Stack Atlas';
const desc =
  description ??
  'A trilingual (中/EN/日) field guide to the modern AI stack: coding agents, CLIs, agent harnesses and infrastructure.';

// Canonical URL for the deployed (GitHub Pages) site. Harmless for the offline
// file:// artifact, where these tags are simply ignored. Undefined if no `site`.
const canonical = Astro.site
  ? new URL(import.meta.env.BASE_URL, Astro.site).href
  : undefined;
// Social-share card (1200x630). Lives at <site>/og.png (public/og.png, generated
// by brand/make-og.mjs). Absolute URL so scrapers can fetch it; only emitted when
// `site` is configured (the offline file:// build has no canonical host).
const ogImage = canonical ? new URL('og.png', canonical).href : undefined;

// Favicon inlined as a data URI so the single file needs no external assets.
// Source master: brand/icon.svg (built with ai-iconflow). An isometric stack of
// three diamond layers (model -> harness -> infrastructure) in the brand
// teal->blue gradient. To regenerate: edit brand/icon.svg, then
// `python -m iconflow build brand/icon.svg --out brand/out --targets web` and
// re-encode brand/out/favicon.svg as a data URI.
const favicon =
  "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%201024%201024%22%3E%3Cdefs%3E%3CradialGradient%20id%3D%22bgGlow%22%20cx%3D%220.5%22%20cy%3D%220.3%22%20r%3D%220.8%22%3E%3Cstop%20offset%3D%220%22%20stop-color%3D%22%231b2842%22%2F%3E%3Cstop%20offset%3D%221%22%20stop-color%3D%22%230b0e14%22%2F%3E%3C%2FradialGradient%3E%3CradialGradient%20id%3D%22stackGlow%22%20cx%3D%220.5%22%20cy%3D%220.5%22%20r%3D%220.5%22%3E%3Cstop%20offset%3D%220%22%20stop-color%3D%22%235be3c9%22%20stop-opacity%3D%220.30%22%2F%3E%3Cstop%20offset%3D%221%22%20stop-color%3D%22%235be3c9%22%20stop-opacity%3D%220%22%2F%3E%3C%2FradialGradient%3E%3C%2Fdefs%3E%3Crect%20width%3D%221024%22%20height%3D%221024%22%20rx%3D%22220%22%20fill%3D%22url%28%23bgGlow%29%22%2F%3E%3Cellipse%20cx%3D%22512%22%20cy%3D%22504%22%20rx%3D%22300%22%20ry%3D%22280%22%20fill%3D%22url%28%23stackGlow%29%22%2F%3E%3Cg%20stroke%3D%22%230a1422%22%20stroke-width%3D%228%22%20stroke-linejoin%3D%22round%22%3E%3Cpolygon%20points%3D%22262%2C760%20512%2C660%20762%2C760%20512%2C860%22%20fill%3D%22%237c9cff%22%2F%3E%3Cpolygon%20points%3D%22262%2C760%20512%2C860%20512%2C908%20262%2C808%22%20fill%3D%22%235571d6%22%2F%3E%3Cpolygon%20points%3D%22512%2C860%20762%2C760%20762%2C808%20512%2C908%22%20fill%3D%22%233d50ab%22%2F%3E%3Cpolygon%20points%3D%22262%2C480%20512%2C380%20762%2C480%20512%2C580%22%20fill%3D%22%236ec1ec%22%2F%3E%3Cpolygon%20points%3D%22262%2C480%20512%2C580%20512%2C628%20262%2C528%22%20fill%3D%22%233e8fcf%22%2F%3E%3Cpolygon%20points%3D%22512%2C580%20762%2C480%20762%2C528%20512%2C628%22%20fill%3D%22%232a6ba6%22%2F%3E%3Cpolygon%20points%3D%22262%2C200%20512%2C100%20762%2C200%20512%2C300%22%20fill%3D%22%237becdb%22%2F%3E%3Cpolygon%20points%3D%22262%2C200%20512%2C300%20512%2C348%20262%2C248%22%20fill%3D%22%2334bda6%22%2F%3E%3Cpolygon%20points%3D%22512%2C300%20762%2C200%20762%2C248%20512%2C348%22%20fill%3D%22%231f9082%22%2F%3E%3C%2Fg%3E%3C%2Fsvg%3E";
---
<!doctype html>
<html lang="en" data-theme="dark" data-lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AI Stack Atlas" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:locale:alternate" content="ja_JP" />
    {canonical && <link rel="canonical" href={canonical} />}
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    {ogImage && <meta property="og:image:alt" content="AI Stack Atlas — a trilingual field guide to the modern AI stack" />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0b0e14" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f6f8fc" media="(prefers-color-scheme: light)" />
    <link rel="icon" href={favicon} />
    {/* Without JS the router can't switch views, so reveal them all (the page
        still works as a long scroll; `is:inline` keeps this scoped to <noscript>). */}
    <noscript>
      <style is:inline>.view[hidden] { display: block !important; }</style>
    </noscript>
    {/* Set lang + theme before paint to avoid flash. */}
    <script is:inline>
      (function () {
        try {
          var L = localStorage.getItem('aistack-lang');
          if (!L) {
            var n = (navigator.language || 'zh').toLowerCase();
            L = n.startsWith('ja') ? 'ja' : n.startsWith('en') ? 'en' : 'zh';
          }
          document.documentElement.setAttribute('data-lang', L);
          document.documentElement.setAttribute('lang', L === 'zh' ? 'zh-Hans' : L);
          var T = localStorage.getItem('aistack-theme');
          if (!T) {
            T = (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) ? 'light' : 'dark';
          }
          document.documentElement.setAttribute('data-theme', T);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main"><L t={{ zh: '跳到主要内容', en: 'Skip to content', ja: '本文へスキップ' }} /></a>
    <Header />
    <main class="wrap" id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />

    {/* ---- language + theme controls ---- */}
    <script is:inline>
      (function () {
        var root = document.documentElement;
        function syncLang() {
          var cur = root.getAttribute('data-lang');
          document.querySelectorAll('#langseg button').forEach(function (b) {
            b.setAttribute('aria-pressed', b.getAttribute('data-lang') === cur ? 'true' : 'false');
          });
        }
        document.querySelectorAll('#langseg button').forEach(function (b) {
          b.addEventListener('click', function () {
            var l = b.getAttribute('data-lang');
            root.setAttribute('data-lang', l);
            root.setAttribute('lang', l === 'zh' ? 'zh-Hans' : l);
            try { localStorage.setItem('aistack-lang', l); } catch (e) {}
            syncLang();
          });
        });
        var tb = document.getElementById('themebtn');
        if (tb) {
          tb.addEventListener('click', function () {
            var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            root.setAttribute('data-theme', next);
            try { localStorage.setItem('aistack-theme', next); } catch (e) {}
          });
        }
        syncLang();
      })();
    </script>

    {/* ---- single-page view router (works from file://) ---- */}
    <script is:inline>
      (function () {
        var views = Array.prototype.slice.call(document.querySelectorAll('[data-view]'));
        var navlinks = Array.prototype.slice.call(document.querySelectorAll('#mainnav a[data-go]'));
        var valid = {};
        views.forEach(function (v) {
          valid[v.getAttribute('data-view')] = true;
          // Make views programmatically focusable so navigation moves focus here
          // (so keyboard / screen-reader users follow the view change).
          v.setAttribute('tabindex', '-1');
        });

        function show(name, target, cat, moveFocus) {
          if (!valid[name]) name = 'home';
          var activeView = null;
          views.forEach(function (v) {
            var active = v.getAttribute('data-view') === name;
            v.hidden = !active;
            if (active) activeView = v;
          });
          navlinks.forEach(function (a) {
            a.setAttribute('aria-current', a.getAttribute('data-go') === name ? 'page' : 'false');
          });
          // Optional: apply a catalog category filter.
          if (name === 'catalog' && cat && window.__catalogSetCat) {
            window.__catalogSetCat(cat);
          }
          // On user navigation, move focus into the new view (not on first paint).
          if (moveFocus && activeView) {
            try { activeView.focus({ preventScroll: true }); } catch (e) { activeView.focus(); }
          }
          // Scroll: to a target element, or to top of the view.
          if (target) {
            var el = activeView ? activeView.querySelector('#' + CSS.escape(target)) : document.getElementById(target);
            if (el) { el.scrollIntoView({ block: 'start' }); return; }
          }
          window.scrollTo(0, 0);
        }

        function go(name, target, cat) {
          var hash = '#' + name + (cat ? '/cat=' + cat : target ? '/' + target : '');
          if (location.hash !== hash) {
            history.pushState({ v: name, t: target, c: cat }, '', hash);
          }
          show(name, target, cat, true);
        }

        // Parse "#view", "#view/target", "#view/cat=xxx"
        function parse() {
          var h = (location.hash || '').replace(/^#/, '');
          if (!h) return { name: 'home' };
          var slash = h.indexOf('/');
          if (slash === -1) return { name: h };
          var name = h.slice(0, slash);
          var rest = h.slice(slash + 1);
          if (rest.indexOf('cat=') === 0) return { name: name, cat: rest.slice(4) };
          return { name: name, target: rest };
        }

        // Intercept any element with data-go.
        document.addEventListener('click', function (e) {
          var a = e.target.closest('[data-go]');
          if (!a) return;
          e.preventDefault();
          go(a.getAttribute('data-go'), a.getAttribute('data-target') || null, a.getAttribute('data-cat') || null);
        });

        window.addEventListener('popstate', function () {
          var p = parse();
          show(p.name, p.target, p.cat, true);
        });

        var init = parse();
        show(init.name, init.target, init.cat);
      })();
    </script>
  </body>
</html>
