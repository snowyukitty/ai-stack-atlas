---
import L from '../L.astro';
import { ui } from '../../data/ui';
import { products } from '../../data/products';
import type { Product } from '../../lib/types';

const models = products.filter((p) => p.category === 'model');
const clis = products.filter((p) => p.category === 'coding-cli');
const music = products.filter((p) => p.category === 'music-gen');
const videos = products.filter((p) => p.category === 'video-gen');
const images = products.filter((p) => p.category === 'image-gen');
const voices = products.filter((p) => p.category === 'voice-clone');
const models3d = products.filter((p) => p.category === '3d-gen');
const avatars = products.filter((p) => p.category === 'avatar-gen');

/** Pull a benchmark value off a product by matching its label. */
const bench = (p: Product, re: RegExp) => p.benchmarks?.find((b) => re.test(b.label))?.value ?? '—';

const licenseLabel = {
  open: { cls: 'open', t: ui.labels.openSource },
  partial: { cls: 'partial', t: ui.labels.partialOpen },
  closed: { cls: '', t: ui.labels.closed },
};

const link = (p: Product) => '#catalog/p-' + p.id;
const stars = (r?: number) => (typeof r === 'number' ? '★'.repeat(r) + '☆'.repeat(5 - r) : '—');
---
<section class="view" data-view="compare" hidden>
  <section class="block">
    <div class="section-head">
      <p class="kicker"><L t={ui.nav.compare} /></p>
      <h2><L t={{ zh: '横向对比', en: 'Side-by-side comparison', ja: '横並び比較' }} /></h2>
      <p><L t={{
        zh: '把同类产品摊开成一张表，逐列比关键维度。数字随版本变化，点名称可跳到完整卡片。',
        en: 'The same class of product laid out in one table, column by column on the dimensions that matter. Figures shift with each release; click a name for the full card.',
        ja: '同種の製品を 1 つの表に並べ、重要な軸を列ごとに比較。数値はリリースごとに変動。名称をクリックで詳細カードへ。',
      }} /></p>
    </div>

    {/* ---------- Frontier models ---------- */}
    <h3 class="cmp-h">🧠 <L t={{ zh: '前沿模型', en: 'Frontier models', ja: 'フロンティアモデル' }} /></h3>
    <div class="matrix-scroll">
      <table class="matrix">
        <thead>
          <tr>
            <th><L t={{ zh: '模型', en: 'Model', ja: 'モデル' }} /></th>
            <th>AA Index</th>
            <th>SWE-bench Pro</th>
            <th>Terminal-Bench</th>
            <th><L t={{ zh: '上下文', en: 'Context', ja: '文脈' }} /></th>
            <th><L t={ui.labels.pricing} /> <span class="th-sub">$/1M</span></th>
            <th><L t={ui.labels.license} /></th>
          </tr>
        </thead>
        <tbody>
          {models.map((p) => (
            <tr>
              <th scope="row">
                <a href={link(p)} data-go="catalog" data-target={'p-' + p.id}>{p.name}</a>
                <span class="vendor">{p.vendor}</span>
              </th>
              <td>{bench(p, /intelligence|aa index/i)}</td>
              <td>{bench(p, /swe-bench/i)}</td>
              <td>{bench(p, /terminal/i)}</td>
              <td>{bench(p, /context/i)}</td>
              <td class="nowrap"><L t={p.pricing} /></td>
              <td><span class={`lic ${licenseLabel[p.license].cls}`}><L t={licenseLabel[p.license].t} /></span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="src"><L t={{
      zh: '“#” 为该基准公榜名次。Fable 5 编程基准登顶，但综合 AA 指数略低于 Opus 4.8（安全回退所致）。',
      en: 'The “#” is the public leaderboard rank for that benchmark. Fable 5 tops the coding benches but its composite AA Index trails Opus 4.8 (due to its safety fallback).',
      ja: '「#」は各ベンチ公開順位。Fable 5 はコーディングで首位だが、総合 AA 指数は安全回退により Opus 4.8 をやや下回る。',
    }} /></p>

    <hr class="soft" />

    {/* ---------- CLI coding agents ---------- */}
    <h3 class="cmp-h">⌨️ <L t={{ zh: 'CLI 编程智能体', en: 'CLI coding agents', ja: 'CLI コーディングエージェント' }} /></h3>
    <div class="matrix-scroll">
      <table class="matrix">
        <thead>
          <tr>
            <th><L t={{ zh: '工具', en: 'Tool', ja: 'ツール' }} /></th>
            <th><L t={ui.labels.command} /></th>
            <th><L t={ui.labels.models} /></th>
            <th>Terminal-Bench</th>
            <th><L t={ui.labels.license} /></th>
            <th><L t={ui.labels.myRating} /></th>
          </tr>
        </thead>
        <tbody>
          {clis.map((p) => (
            <tr class={p.status === 'sunset' ? 'is-sunset' : undefined}>
              <th scope="row">
                <a href={link(p)} data-go="catalog" data-target={'p-' + p.id}>{p.name}</a>
                <span class="vendor">{p.vendor}{p.status === 'sunset' ? ' · ' : ''}{p.status === 'sunset' ? <L t={ui.labels.sunset} /> : ''}</span>
              </th>
              <td>{p.command ? <code>{p.command}</code> : '—'}</td>
              <td class="models">{p.models.join(', ')}</td>
              <td>{bench(p, /terminal/i)}</td>
              <td><span class={`lic ${licenseLabel[p.license].cls}`}><L t={licenseLabel[p.license].t} /></span></td>
              <td class="rate" title={typeof p.rating === 'number' ? `${p.rating}/5` : ''}>{stars(p.rating)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="src"><L t={{
      zh: '评分为个人主观 0–5；“—” 表示该项不适用或无公开数据。',
      en: 'Ratings are a personal 0–5 take; “—” means not applicable or no public figure.',
      ja: '評価は個人の主観 0–5。「—」は該当なし／公開値なし。',
    }} /></p>

    <hr class="soft" />

    {/* ---------- AI music generation ---------- */}
    <h3 class="cmp-h">🎵 <L t={{ zh: 'AI 音乐生成', en: 'AI music generation', ja: 'AI 音楽生成' }} /></h3>
    <div class="matrix-scroll">
      <table class="matrix">
        <thead>
          <tr>
            <th><L t={{ zh: '平台', en: 'Platform', ja: 'プラットフォーム' }} /></th>
            <th><L t={{ zh: '类型', en: 'Kind', ja: '種別' }} /></th>
            <th><L t={{ zh: '人声', en: 'Vocals', ja: 'ボーカル' }} /></th>
            <th><L t={{ zh: '分轨', en: 'Stems', ja: 'ステム' }} /></th>
            <th><L t={ui.labels.pricing} /></th>
            <th><L t={ui.labels.myRating} /></th>
          </tr>
        </thead>
        <tbody>
          {music.map((p) => (
            <tr>
              <th scope="row">
                <a href={link(p)} data-go="catalog" data-target={'p-' + p.id}>{p.name}</a>
                <span class="vendor">{p.vendor}</span>
              </th>
              <td><L t={p.subtype} /></td>
              <td>{p.tags.includes('vocals') || p.id === 'suno' || p.id === 'udio' ? '✓' : '—'}</td>
              <td>{p.id === 'udio' || p.id === 'suno' ? '✓ (paid)' : p.id === 'aiva' ? 'MIDI' : '—'}</td>
              <td class="nowrap"><L t={p.pricing} /></td>
              <td class="rate" title={typeof p.rating === 'number' ? `${p.rating}/5` : ''}>{stars(p.rating)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="src"><L t={{
      zh: 'Suno 最易出完整歌曲；Udio 编曲与分轨最强；ElevenLabs 适合品牌配乐；AIVA 专攻古典 / 影视。',
      en: 'Suno is the easiest full-song path; Udio leads on arrangement and stems; ElevenLabs fits brand beds; AIVA owns classical/film.',
      ja: 'Suno が最も手軽なフルソング。Udio は編曲とステム最強。ElevenLabs はブランド BGM。AIVA はクラシック／映像。',
    }} /></p>

    <hr class="soft" />

    {/* ---------- AI video generation ---------- */}
    <h3 class="cmp-h">🎬 <L t={{ zh: 'AI 视频生成', en: 'AI video generation', ja: 'AI 動画生成' }} /></h3>
    <div class="matrix-scroll">
      <table class="matrix">
        <thead>
          <tr>
            <th><L t={{ zh: '平台', en: 'Platform', ja: 'プラットフォーム' }} /></th>
            <th>Video Arena</th>
            <th><L t={{ zh: '原生音频', en: 'Native audio', ja: 'ネイティブ音声' }} /></th>
            <th><L t={{ zh: '图生视频', en: 'I2V', ja: 'I2V' }} /></th>
            <th><L t={ui.labels.pricing} /></th>
            <th><L t={ui.labels.myRating} /></th>
          </tr>
        </thead>
        <tbody>
          {videos.map((p) => (
            <tr>
              <th scope="row">
                <a href={link(p)} data-go="catalog" data-target={'p-' + p.id}>{p.name}</a>
                <span class="vendor">{p.vendor}</span>
              </th>
              <td>{bench(p, /video arena/i)}</td>
              <td>{p.tags.includes('audio-sync') || p.id === 'veo-3' || p.id === 'sora-2' ? '✓' : '—'}</td>
              <td>{p.tags.includes('i2v') ? '✓' : '—'}</td>
              <td class="nowrap"><L t={p.pricing} /></td>
              <td class="rate" title={typeof p.rating === 'number' ? `${p.rating}/5` : ''}>{stars(p.rating)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="src"><L t={{
      zh: 'Video Arena 为 LLM Stats 盲测分（2026-07）。Kling v3 运动居首；LTX-2 秒价最低；Sora 2 / Veo 3 带原生音画同步。',
      en: 'Video Arena scores are LLM Stats blind votes (2026-07). Kling v3 leads motion; LTX-2 has the lowest $/s; Sora 2 / Veo 3 ship native A/V sync.',
      ja: 'Video Arena は LLM Stats 盲測（2026-07）。Kling v3 が運動首位。LTX-2 は秒単価最安。Sora 2／Veo 3 はネイティブ音画同期。',
    }} /></p>

    <hr class="soft" />

    {/* ---------- AI image generation ---------- */}
    <h3 class="cmp-h">🖼️ <L t={{ zh: 'AI 图像生成', en: 'AI image generation', ja: 'AI 画像生成' }} /></h3>
    <div class="matrix-scroll">
      <table class="matrix">
        <thead>
          <tr>
            <th><L t={{ zh: '平台', en: 'Platform', ja: 'プラットフォーム' }} /></th>
            <th>Image Arena</th>
            <th><L t={{ zh: '自托管', en: 'Self-host', ja: '自己ホスト' }} /></th>
            <th><L t={{ zh: '文字渲染', en: 'In-image text', ja: '文字描画' }} /></th>
            <th><L t={ui.labels.pricing} /></th>
            <th><L t={ui.labels.myRating} /></th>
          </tr>
        </thead>
        <tbody>
          {images.map((p) => (
            <tr>
              <th scope="row">
                <a href={link(p)} data-go="catalog" data-target={'p-' + p.id}>{p.name}</a>
                <span class="vendor">{p.vendor}</span>
              </th>
              <td>{bench(p, /image arena|elo/i)}</td>
              <td>{p.tags.includes('self-host') || p.license === 'open' || p.license === 'partial' ? '✓' : '—'}</td>
              <td>{p.tags.includes('text-rendering') ? '★★★★★' : p.id === 'gpt-image-2' || p.id === 'ideogram-4' ? '★★★★' : '—'}</td>
              <td class="nowrap"><L t={p.pricing} /></td>
              <td class="rate" title={typeof p.rating === 'number' ? `${p.rating}/5` : ''}>{stars(p.rating)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="src"><L t={{
      zh: 'Image Arena 为 Artificial Analysis 盲测 Elo（2026）。GPT Image 2 居首；Ideogram 文字最强；Flux / SD 可自托管。',
      en: 'Image Arena = Artificial Analysis blind Elo (2026). GPT Image 2 leads; Ideogram owns text; Flux / SD self-host.',
      ja: 'Image Arena は Artificial Analysis 盲測 Elo（2026）。GPT Image 2 首位。Ideogram が文字最強。Flux／SD は自己ホスト可。',
    }} /></p>

    <hr class="soft" />

    {/* ---------- Voice cloning / TTS ---------- */}
    <h3 class="cmp-h">🎙️ <L t={{ zh: '语音克隆 / TTS', en: 'Voice cloning / TTS', ja: '音声クローン / TTS' }} /></h3>
    <div class="matrix-scroll">
      <table class="matrix">
        <thead>
          <tr>
            <th><L t={{ zh: '平台', en: 'Platform', ja: 'プラットフォーム' }} /></th>
            <th><L t={{ zh: '保真度', en: 'Fidelity', ja: '忠実度' }} /></th>
            <th>TTFB</th>
            <th><L t={{ zh: '最短样本', en: 'Min sample', ja: '最短サンプル' }} /></th>
            <th><L t={{ zh: '自托管', en: 'Self-host', ja: '自己ホスト' }} /></th>
            <th><L t={ui.labels.myRating} /></th>
          </tr>
        </thead>
        <tbody>
          {voices.map((p) => (
            <tr>
              <th scope="row">
                <a href={link(p)} data-go="catalog" data-target={'p-' + p.id}>{p.name}</a>
                <span class="vendor">{p.vendor}</span>
              </th>
              <td>{bench(p, /fidelity/i)}</td>
              <td>{bench(p, /ttfb/i)}</td>
              <td>{bench(p, /min sample|min clone|ivc min/i)}</td>
              <td>{p.tags.includes('self-host') || p.license === 'open' ? '✓' : '—'}</td>
              <td class="rate" title={typeof p.rating === 'number' ? `${p.rating}/5` : ''}>{stars(p.rating)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="src"><L t={{
      zh: '未经同意克隆他人声音违法。生产环境须备书面同意与输出披露。Cartesia 延迟最低；ElevenLabs 保真最高。',
      en: 'Cloning without consent is illegal. Production needs written consent and disclosure. Cartesia = lowest latency; ElevenLabs = top fidelity.',
      ja: '無断クローンは違法。本番は書面同意と開示が必須。Cartesia は遅延最小。ElevenLabs は忠実度最高。',
    }} /></p>

    <hr class="soft" />

    {/* ---------- AI 3D generation ---------- */}
    <h3 class="cmp-h">🧊 <L t={{ zh: 'AI 3D 生成', en: 'AI 3D generation', ja: 'AI 3D 生成' }} /></h3>
    <div class="matrix-scroll">
      <table class="matrix">
        <thead>
          <tr>
            <th><L t={{ zh: '平台', en: 'Platform', ja: 'プラットフォーム' }} /></th>
            <th><L t={{ zh: '生成速度', en: 'Gen speed', ja: '生成速度' }} /></th>
            <th><L t={{ zh: '水密', en: 'Watertight', ja: '水密' }} /></th>
            <th>PBR</th>
            <th><L t={{ zh: '自托管', en: 'Self-host', ja: '自己ホスト' }} /></th>
            <th><L t={ui.labels.myRating} /></th>
          </tr>
        </thead>
        <tbody>
          {models3d.map((p) => (
            <tr>
              <th scope="row">
                <a href={link(p)} data-go="catalog" data-target={'p-' + p.id}>{p.name}</a>
                <span class="vendor">{p.vendor}</span>
              </th>
              <td>{bench(p, /generation speed|speed/i)}</td>
              <td>{p.tags.includes('watertight') || p.id === 'rodin-hyper3d' || p.id === 'neural4d' ? '✓' : p.id === 'tripo3d' ? '✗' : '~'}</td>
              <td>{bench(p, /pbr/i)}</td>
              <td>{p.tags.includes('self-host') || p.license === 'open' ? '✓' : '—'}</td>
              <td class="rate" title={typeof p.rating === 'number' ? `${p.rating}/5` : ''}>{stars(p.rating)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="src"><L t={{
      zh: 'Tripo 最快草稿；Neural4D / Rodin 水密 + PBR；Meshy 游戏风；Hunyuan3D / TRELLIS 可自托管。',
      en: 'Tripo = fastest drafts; Neural4D/Rodin = watertight+PBR; Meshy = game style; Hunyuan3D/TRELLIS = self-host.',
      ja: 'Tripo が最速ドラフト。Neural4D／Rodin は水密＋PBR。Meshy はゲーム風。Hunyuan3D／TRELLIS は自己ホスト可。',
    }} /></p>

    <hr class="soft" />

    {/* ---------- Digital humans / avatars ---------- */}
    <h3 class="cmp-h">👤 <L t={{ zh: '数字人 / Avatar', en: 'Digital humans / avatars', ja: 'デジタルヒューマン' }} /></h3>
    <div class="matrix-scroll">
      <table class="matrix">
        <thead>
          <tr>
            <th><L t={{ zh: '平台', en: 'Platform', ja: 'プラットフォーム' }} /></th>
            <th><L t={{ zh: '语言数', en: 'Languages', ja: '言語数' }} /></th>
            <th><L t={{ zh: '口型同步', en: 'Lip-sync', ja: 'リップシンク' }} /></th>
            <th>API</th>
            <th><L t={ui.labels.pricing} /></th>
            <th><L t={ui.labels.myRating} /></th>
          </tr>
        </thead>
        <tbody>
          {avatars.map((p) => (
            <tr>
              <th scope="row">
                <a href={link(p)} data-go="catalog" data-target={'p-' + p.id}>{p.name}</a>
                <span class="vendor">{p.vendor}</span>
              </th>
              <td>{bench(p, /languages/i)}</td>
              <td>{bench(p, /lip-sync/i)}</td>
              <td>{p.tags.includes('api') || p.id === 'did' || p.id === 'tavus' ? '✓' : p.id === 'heygen' ? '✓' : '—'}</td>
              <td class="nowrap"><L t={p.pricing} /></td>
              <td class="rate" title={typeof p.rating === 'number' ? `${p.rating}/5` : ''}>{stars(p.rating)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="src"><L t={{
      zh: 'HeyGen 多语言与易用综合第一；Synthesia 企业培训；D-ID 开发者 API；Hedra 创意表现力；Tavus 销售个性化。',
      en: 'HeyGen leads multilingual ease; Synthesia for enterprise training; D-ID for dev APIs; Hedra for creative expression; Tavus for sales personalization.',
      ja: 'HeyGen が多言語と易用で総合首位。Synthesia は企業研修。D-ID は開発者 API。Hedra はクリエイティブ。Tavus は営業パーソナライズ。',
    }} /></p>
  </section>
</section>
