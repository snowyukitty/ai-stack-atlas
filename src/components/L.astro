---
/**
 * Renders all language variants; CSS (via html[data-lang]) shows the active one.
 * Order: EN (primary) · JA · 繁 (hant) · 简 (zh, temporarily hidden from the switcher).
 * Traditional is derived from authoring-locale `zh` at build time via OpenCC.
 * Simplified (`zh`) translations stay in the HTML so they can be re-enabled later —
 * only the language-switcher button is hidden for now.
 * Use `block` for paragraph-level content.
 */
import type { Loc } from '../lib/types';
import { toHant } from '../lib/hant';
interface Props {
  t: Loc;
  as?: keyof HTMLElementTagNameMap;
  block?: boolean;
  class?: string;
}
const { t, as = 'span', block = false, class: cls = '' } = Astro.props as Props;
const Tag = as as any;
const wrapClass = (block ? 'i18n-block' : 'i18n') + (cls ? ' ' + cls : '');
---
<Tag class={wrapClass}>
  <span lang="en" set:html={t.en}></span>
  <span lang="ja" set:html={t.ja}></span>
  <span lang="hant" set:html={toHant(t.zh)}></span>
  {/* Simplified: kept in the build, UI switcher temporarily hidden (see Header). */}
  <span lang="zh" set:html={t.zh}></span>
</Tag>
